	<!--    = = = = = = = = = = = = = = = = =
      macrodef: exporter.lcs.file Rules
         This Macrodef execute the windchill com.lcs.wc.load.ExtractFile command
     = = = = = = = = = = = = = = = = = -->
	<macrodef name="exporter.lcs.file">
		<attribute name="objects" default="All"/>
		<attribute name="custom.subfolder" default="sic"/>
		<attribute name="delimiter" default="TAB"/>
		<sequential>
			<var name="nowts_export" unset="true"/>
			<tstamp>
				<format property="nowts_export" pattern="yyyyMMdd-hhmmss" />
			</tstamp>
			<var name="export.location" unset="true" />
			<property name="export.location" value="${wt.loadfiles.dir}/@{custom.subfolder}/lcsextracts/LCS_files_${nowts_export}"/>
			<mkdir dir="${export.location}"/>
			
			<log message="= = = = = = = = = = = = = = = =" />
			<log message=" - Exporting LCS Objects [@{objects}] on Folder [${export.location}]" />
			<log message="= = = = = = = = = = = = = = = =" />

			<exec-cmd executable="${wc_cmd}" failonerror="true" inputstring="Y&#xA;" action="exporter.lcs.file" parameters="[objects=@{objects}|custom.subfolder=@{custom.subfolder}|delimiter=@{delimiter}]">
				<args>
					<arg line="${extra.java.args}" />
					<arg value="com.lcs.wc.load.ExtractFile"/>
					<arg line="${username.and.password}" />
					<arg value="${export.location}" />
					<arg value="@{delimiter}" />
					<arg line="@{objects}" />
				</args>
			</exec-cmd>

			<log message="= = = = = = = = = = = = = = = =" />
			<log message=" - LCS Objects [@{objects}] have been exported on Folder [${export.location}]" />
			<log message="= = = = = = = = = = = = = = = =" />
			
			<zip.clean.log filename="LCS_files_${nowts_export}"
				basedir="${wt.loadfiles.dir}/@{custom.subfolder}/lcsextracts"
				message="Extracted LCS Files"
				target.location="${installer.logs.dir}/@{custom.subfolder}/lcsextracts"/>
		</sequential>
	</macrodef>


	<!--    = = = = = = = = = = = = = = = = =
      macrodef: exporter.agvr
         This Macrodef execute the windchill com.lcs.wc.load.ExtractAGAR command
     = = = = = = = = = = = = = = = = = -->
	<macrodef name="exporter.agvr">
		<attribute name="custom.subfolder" default="sic"/>
		<attribute name="delimiter" default=","/>

		<sequential>
			<var name="nowts_export" unset="true"/>
			<tstamp>
				<format property="nowts_export" pattern="yyyyMMdd-hhmmss" />
			</tstamp>
			
			<var name="file" unset="true" />
			<property name="file" value="AGVR_Export_${nowts_export}.txt"/>
			<var name="export.location" unset="true" />
			<property name="export.location" value="${installer.logs.dir}/@{custom.subfolder}/agvr"/>
			<mkdir dir="${export.location}"/>
			
			<log message="= = = = = = = = = = = = = = = =" />
			<log message="Exporting AGVR [${file}]" />
			<log message="= = = = = = = = = = = = = = = =" />

			<exec-cmd executable="${wc_cmd}" failonerror="true" inputstring="Y&#xA;" action="exporter.agvr" parameters="[custom.subfolder=@{custom.subfolder}|delimiter=@{delimiter}]">
				<args>
					<arg line="${extra.java.args}" />
					<arg value="com.lcs.wc.load.ExtractAGAR"/>
					<arg line="${username.and.password}" />
					<arg value="-f"/>
					<arg value="${file}" />
					<arg value="-d"/>
					<arg value="@{delimiter}" />
				</args>
			</exec-cmd>
			
			<copy file="${file}" todir="${export.location}"/>
			<delete failonerror="false" file="${file}" />
			
			<log message="= = = = = = = = = = = = = = = =" />
			<log message=" - Exported AGVR added to Folder [${export.location}]" />
			<log message="= = = = = = = = = = = = = = = =" />
			
		</sequential>
	</macrodef>

