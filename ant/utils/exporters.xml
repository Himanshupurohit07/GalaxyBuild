	<macrodef name="zip.clean.log">
		<attribute name="filename" />
		<attribute name="basedir" />
		<attribute name="message" />
		<attribute name="target.location" default="${installer.logs.dir}"/>

		<sequential>
			
			<tar longfile="gnu" compression="none" destfile="@{target.location}/@{filename}.tar">
				<tarfileset dir="@{basedir}/@{filename}/." >
					<include name="**"/>
				</tarfileset>
			</tar>
			<zip destfile="@{target.location}/@{filename}.zip">
				<tarfileset src="@{target.location}/@{filename}.tar"/>
			</zip>
			<delete file="@{target.location}/@{filename}.tar"/>
			
			<if>
				<available file="@{target.location}/@{filename}.zip" type="file" />
				<then>
					<chmod file="@{target.location}/@{filename}.zip" perm="ugo+rw" />
		
					<log message="-----" />
					<log message="   - @{message} added on file [@{target.location}/@{filename}.zip]." />
					<log message="-----" />
				</then>
				<else>
					<log message="-----" />
					<log message="   - @{message} exporter fails !! Check Method Server logs for more details" />
					<log message="-----" />
				</else>
			</if>
	
			<if>
				<available file="@{basedir}/@{filename}" type="file" />
				<then>
					<delete failonerror="false" dir="@{basedir}/@{filename}" />
				</then>
			</if>
			
		</sequential>
	</macrodef>
