<project name="Exporter Utilities">

	<macrodef name="exporter.type">
		<attribute name="custom.subfolder" default="sic"/>
		<attribute name="type"/>
		<attribute name="mode" default="0"/>
		<attribute name="exportancestor" default="false"/>

		<sequential>
			<var name="nowts_export" unset="true"/>
			<tstamp>
				<format property="nowts_export" pattern="yyyyMMdd-hhmmss" />
			</tstamp>

			<var name="updatedType" unset="true"/>
			<var name="updatedFilename" unset="true"/>
			<replaceChar string="@{type}" pattern="\$" replacement="_" to="updatedType" />
			<replaceChar string="@{type}.xml" pattern="\$" replacement="_" to="updatedFilename" />
			
			<var name="tempLoadFile" unset="true" />
			<property name="tempLoadFile" value="${wt.temp}/${updatedType}_${nowts_export}_TypeDefExporter.xml"/>

			<gen.type.definition.exporter.loadfile
				type="@{type}"
				filename="${updatedFilename}"
				export.location="${wt.loadfiles.dir}/@{custom.subfolder}/types/${updatedType}_${nowts_export}"
				mode="@{mode}"
				export.ancestor="@{exportancestor}"
				temp.filepath="${wt.temp}/${updatedType}_${nowts_export}_TypeDefExporter.xml" />

			<log message="= = = = = = = = = = = = = = = =" />
			<log message=" 1 - Exporting Type [@{type}]" />
			<log message="= = = = = = = = = = = = = = = =" />

			<loadFromFile loadfile="${tempLoadFile}" />

			<log message="= = = = = = = = = = = = = = = =" />
			<log message=" 2 - Archiving exported Type" />
			<log message="= = = = = = = = = = = = = = = =" />

			<zip.clean.log filename="${updatedType}_${nowts_export}"
				basedir="${wt.loadfiles.dir}/@{custom.subfolder}/types"
				message="Type Definition"
				target.location="${installer.logs.dir}/@{custom.subfolder}/types"/>

		</sequential>
	</macrodef>

	<macrodef name="gen.type.definition.exporter.loadfile">
		<attribute name="type" />
		<attribute name="filename" />
		<attribute name="export.location" />
		<attribute name="mode" default="0" />
		<attribute name="export.ancestor" default="false" />
		<attribute name="temp.filepath" />

		<sequential>
			<var name="thetype" unset="true" />
			<property name="thetype" value="@{type}"/>
			<var name="thefilename" unset="true" />
			<property name="thefilename" value="@{filename}"/>
			<var name="xmltargetfile" unset="true" />
			<property name="xmltargetfile" value="@{temp.filepath}"/>
			<var name="theexport.location" unset="true" />
			<property name="theexport.location" value="@{export.location}"/>
			<var name="themode" unset="true" />
			<property name="themode" value="@{mode}"/>
			<var name="theexport.ancestor" unset="true" />
			<property name="theexport.ancestor" value="@{export.ancestor}"/>

			<groovy>
				def xmlTargetFile = ant.project.getProperty("xmltargetfile");

				def type = ant.project.getProperty("thetype");
				def filename = ant.project.getProperty("thefilename");
				def mode = ant.project.getProperty("themode");
				def ancestor = ant.project.getProperty("theexport.ancestor");
				def location = ant.project.getProperty("theexport.location");

				def writer = new StringWriter()
				def builder = new groovy.xml.MarkupBuilder(writer)
				def helper = new groovy.xml.MarkupBuilderHelper(builder)
				helper.xmlDeclaration([version:'1.0', encoding:'UTF-8'])
				helper.yieldUnescaped """&lt;!DOCTYPE NmLoader SYSTEM "standardX24.dtd"&gt;"""+"\n"
				builder.NmLoader {
					csvExportDefinition( handler: "com.ptc.core.lwc.server.TypeDefinitionExporter.beginExportDefinition" ) {
						csvtoLocation(location)
						csvtoFileName(filename)
						csvexportDefClass("com.ptc.core.lwc.server.LWCTypeDefinition")
						csvexportNames(type)
						csvmode(mode)
						csvExportAncestorTypes(ancestor)
					}
				}
				File xmlFile = new File (xmlTargetFile)
				xmlFile.append(writer.toString())
			</groovy>
		</sequential>
	</macrodef>

