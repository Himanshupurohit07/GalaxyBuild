	<!--    = = = = = = = = = = = = = = = = =
              macrodef: loadFileSet
        This Macrodef execute the winchill wt.load.LoadFileSet command
             = = = = = = = = = = = = = = = = = -->
	<macrodef name="loadFileSet">
		<attribute name="loadfileset" />
		<attribute name="enforce" default="false" />

		<sequential>
			<if>
				<equals arg1="${list.content.only}" arg2="true" />
				<then>
					<log message="Print Package Content - Skipping loadFileSet" />
				</then>
				<else>
					<if>
						<available file="@{loadfileset}" />
						<then>

							<exec-cmd executable="${wc_cmd}" failonerror="true" action="loadFileSet" enforce="@{enforce}" checksumreference="@{loadfileset}" parameters="[loadfileset=@{loadfileset}|enforce=@{enforce}]">
								<args>
									<arg line="${extra.java.args}" />
									<arg value="wt.load.LoadFileSet" />
									<arg value="-file" />
									<arg value="@{loadfileset}" />
									<arg line="${username.and.password}" />
									<arg value="-Unattended" />
									<arg value="-NOServerStop" />
								</args>
							</exec-cmd>
						</then>
						<else>
							<log />
							<log />
							<log message="= = = = = = = = = = = = = = = =" />
							<log message="Cannot Execute [loadFileSet]" />
							<log message="  with parameters" />
							<log message="    [loadfileset=@{loadfileset}|enforce=@{enforce}]" />
							<log message=" - File @{loadfileset} does not exist !" />
							<log message="= = = = = = = = = = = = = = = =" />
							<append.to.file message="ERROR ${csv.sep} loadFileSet ${csv.sep} [loadfileset=@{loadfileset}|enforce=@{enforce}] ${csv.sep} File @{loadfileset} does not exist !" error="true" />
						</else>
					</if>
				</else>
			</if>
		</sequential>
	</macrodef>

	<!--    = = = = = = = = = = = = = = = = =
              macrodef: loadFromFile
