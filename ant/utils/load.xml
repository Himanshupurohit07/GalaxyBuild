		<attribute name="loadfile" />
		<attribute name="enforce" default="false" />
		<attribute name="contpath" default="/" />

		<sequential>
			<if>
				<equals arg1="${list.content.only}" arg2="true" />
				<then>
					<log message="Print Package Content - Skipping loadFromFile" />
				</then>
				<else>
					<if>
						<available file="@{loadfile}" />
						<then>
							<exec-cmd executable="${wc_cmd}" failonerror="true" action="loadFromFile" enforce="@{enforce}" checksumreference="@{loadfile}" parameters="[loadfile=@{loadfile}|contpath=@{contpath}|enforce=@{enforce}]">
								<args>
									<arg line="${extra.java.args}" />
									<arg value="wt.load.LoadFromFile" />
									<arg value="-d" />
									<arg value="@{loadfile}" />
									<arg line="${username.and.password}" />
									<arg value="-CONT_PATH" />
									<arg value="@{contpath}" />
								</args>
							</exec-cmd>
						</then>
						<else>
							<log />
							<log />
							<log message="= = = = = = = = = = = = = = = =" />
							<log message="Cannot Execute [loadFromFile]" />
							<log message="  with parameters" />
							<log message="    [loadfile=@{loadfile}|contpath=@{contpath}|enforce=@{enforce}]" />
							<log message=" - File @{loadfile} does not exist !" />
							<log message="= = = = = = = = = = = = = = = =" />
							<append.to.file message="ERROR ${csv.sep} loadfile ${csv.sep} [loadfile=@{loadfile}|contpath=@{contpath}|enforce=@{enforce}] ${csv.sep} File @{loadfile} does not exist !" error="true" />
						</else>
					</if>
				</else>
			</if>
		</sequential>
	</macrodef>

	<!--    = = = = = = = = = = = = = = = = =
              macrodef: loadCSVLoadFile
        This Macrodef execute the winchill wt.load.LoadFromFile command using both a map file and a csv file
             = = = = = = = = = = = = = = = = = -->
	<macrodef name="loadCSVLoadFile">
		<attribute name="mapfile" />
		<attribute name="loadfile" />
		<attribute name="contpath" default="/" />

		<sequential>
			<if>
				<equals arg1="${list.content.only}" arg2="true" />
				<then>
					<log message="Print Package Content - Skipping loadFromFile" />
				</then>
				<else>
					<if>
						<and>
							<available file="@{mapfile}" />
							<available file="@{loadfile}" />
						</and>
						<then>
							<exec-cmd executable="${wc_cmd}" failonerror="true" action="loadFromFile" checksumreference="@{loadfile}" parameters="[loadfile=@{loadfile}|mapfile=@{mapfile}|contpath=@{contpath}]">
								<args>
									<arg line="${extra.java.args}" />
									<arg value="wt.load.LoadFromFile" />
									<arg value="-m" />
									<arg value="@{mapfile}" />
									<arg value="-g" />
									<arg value="create" />
									<arg value="-d" />
									<arg value="@{loadfile}" />
									<arg line="${username.and.password}" />
									<arg value="-CONT_PATH" />
									<arg value="@{contpath}" />
								</args>
							</exec-cmd>
						</then>
						<else>
							<log />
							<log />
							<log message="= = = = = = = = = = = = = = = =" />
							<log message="Cannot Execute [loadCSVLoadFile]" />
							<log message="  with parameters" />
							<log message="    [loadfile=@{loadfile}|mapfile=@{mapfile}|contpath=@{contpath}]" />
							<log message=" - File Loadfile [@{loadfile}] or Mapfile [@{mapfile}] does not exist !" />
							<log message="= = = = = = = = = = = = = = = =" />
							<append.to.file message="ERROR ${csv.sep} loadfile ${csv.sep} [loadfile=@{loadfile}|mapfile=@{mapfile}|contpath=@{contpath}] ${csv.sep} File @{loadfile} does not exist !" error="true" />
						</else>
					</if>
				</else>
			</if>
		</sequential>
	</macrodef>

