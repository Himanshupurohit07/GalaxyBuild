	<!--    = = = = = = = = = = = = = = = = =
	      macrodef: importBAC
	         This Macrodef execute the windchill wt.scm.client.SCMCMD import 
	     = = = = = = = = = = = = = = = = = -->
	<macrodef name="importBAC">
		<attribute name="file" />
		<attribute name="conflictResolutionFile" default="" />
		<attribute name="mapFile" default="" />

		<sequential>

			<if>
				<available file="${wt.bin.dir}${dir.sep}customizationTools${dir.sep}templates${dir.sep}defaultConflictResolution.xml" type="file" />
				<then>
					<var name="aConflictResolutionFile" unset="true"/>
					<property name="aConflictResolutionFile" value="${wt.bin.dir}${dir.sep}customizationTools${dir.sep}templates${dir.sep}defaultConflictResolution.xml" />
					<log message="Default ConflictResolution.xml file found. Using it." />
				</then>
				<else>
					<if>
						<available file="@{conflictResolutionFile}" type="file" />
						<then>
							<var name="aConflictResolutionFile" unset="true"/>
							<property name="aConflictResolutionFile" value="@{conflictResolutionFile}" />
						</then>
						<else>
							<var name="aConflictResolutionFile" unset="true"/>
							<property name="aConflictResolutionFile" value="" />

						</else>
					</if>
				</else>
			</if>

			<if>
				<available file="@{mapFile}" type="file" />
				<then>
					<var name="aMapFile" unset="true"/>
					<property name="aMapFile" value="@{mapFile}" />
				</then>
				<else>
					<var name="aMapFile" unset="true"/>
					<property name="aMapFile" value="" />
				</else>
			</if>

			<if>
				<equals arg1="${list.content.only}" arg2="true" />
				<then>
					<log message="Print Package Content - Skipping loadBAC" />
				</then>
				<else>
					<if>
						<available file="@{file}" />
						<then>
							<enableBACLoggers />
							<exec-cmd executable="${wc_cmd}" failonerror="true" action="importBAC" checksumreference="@{file}" parameters="[file=@{file}]">
								<args>
									<arg line="${extra.java.args}" />
									<arg value="wt.scm.client.SCMCMD" />
									<arg value="import" />
									<arg value="-u" />
									<arg value="${wcadmin.username}" />
									<arg value="-p" unless:blank="${wcadmin.password}" />
									<arg value="${wcadmin.password}" unless:blank="${wcadmin.password}" />
									<arg value="-f" />
									<arg value="@{file}" />
									<arg value="-c" unless:blank="${aConflictResolutionFile}" />
									<arg value="${aConflictResolutionFile}" unless:blank="${aConflictResolutionFile}" />
									<arg value="-m" unless:blank="${aMapFile}" />
									<arg value="${aMapFile}" unless:blank="${aMapFile}" />
									<arg value="-d" />
									<arg value="-o" />
									<arg value="${installer.logs.dir}" />
								</args>
							</exec-cmd>
							<disableBACLoggers />
						</then>
						<else>
							<log />
							<log />
							<log message="= = = = = = = = = = = = = = = =" />
							<log message="Cannot Execute [importBAC]" />
							<log message="  with parameters" />
							<log message="    [file=@{file}]" />
							<log message=" - File @{file} does not exist !" />
							<log message="= = = = = = = = = = = = = = = =" />
							<append.to.file message="ERROR ${csv.sep} importBAC ${csv.sep} [file=@{file}] ${csv.sep} File @{file} does not exist !" error="true" />
						</else>
					</if>
				</else>
			</if>
		</sequential>
	</macrodef>

	<!--    = = = = = = = = = = = = = = = = =
	      macrodef: enableBACLoggers
	         This Macrodef Increase BAC Log Levels command
	     = = = = = = = = = = = = = = = = = -->
	<macrodef name="enableBACLoggers">
		<sequential>
			<setLogLevel logger="com.ptc.windchill.bac" loglevel="ALL" />
			<setLogLevel logger="com.ptc.windchill.rd" loglevel="ALL" />
			<setLogLevel logger="wt.queue" loglevel="ALL" />
			<setLogLevel logger="com.ptc.windchill.bac.thread.BACThreadDumpLogger" loglevel="ALL" />
		</sequential>
	</macrodef>

	<!--    = = = = = = = = = = = = = = = = =
	      macrodef: disableBACLoggers
	         This Macrodef Re-Init BAC Log Levels command
	     = = = = = = = = = = = = = = = = = -->
	<macrodef name="disableBACLoggers">
		<sequential>
			<setLogLevel logger="com.ptc.windchill.bac" loglevel="ERROR" />
			<setLogLevel logger="com.ptc.windchill.rd" loglevel="ERROR" />
			<setLogLevel logger="wt.queue" loglevel="ERROR" />
			<setLogLevel logger="com.ptc.windchill.bac.thread.BACThreadDumpLogger" loglevel="ERROR" />
		</sequential>
	</macrodef>

