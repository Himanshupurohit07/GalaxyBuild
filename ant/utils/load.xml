	<!--    = = = = = = = = = = = = = = = = =
	      macrodef: loadLCSLoadFile
		 This Macrodef execute the loading of LCS Load Files
		   using mapfile and loadfile
	     = = = = = = = = = = = = = = = = = -->
	<macrodef name="loadLCSLoadFile">
		<attribute name="mapfile" />
		<attribute name="datafile" />
		<attribute name="delimiter" default="TAB"/>
		<sequential>
			<if>
				<equals arg1="${list.content.only}" arg2="true" />
				<then>
					<log message="Print Package Content - Skipping loadLCSLoadFile" />
				</then>
				<else>
					<if>
						<and>
							<available file="@{mapfile}" />
							<available file="@{datafile}" />
						</and>
						<then>
							<exec-cmd executable="${wc_cmd}" failonerror="true" inputstring="Y&#xA;" action="loadLCSLoadFile" checksumreference="@{datafile}" parameters="[mapfile=@{mapfile}|datafile=@{datafile}|delimiter=@{delimiter}]">
								<args>
									<arg line="${extra.java.args}" />
									<arg value="com.lcs.wc.load.LCSLoadFile" />
									<arg line="${username.and.password}" />
									<arg value="-d" />
									<arg value="@{delimiter}" />
									<arg value="-m" />
									<arg value="@{mapfile}" />
									<arg value="@{datafile}" />
								</args>
							</exec-cmd>
						</then>
						<else>
							<var name="errorLCS" value=""/>
							<if>
								<not>
									<available file="@{mapfile}" />
								</not>
								<then>
									<var name="errorLCS" value="${errorLCS}MapFile @{mapfile} does not exist ! "/>
								</then>
							</if>
							<if>
								<not>
									<available file="@{datafile}" />
								</not>
								<then>
									<var name="errorLCS" value="${errorLCS}DataFile @{datafile} does not exist ! "/>
								</then>
							</if>

							<log />
							<log />
							<log message="= = = = = = = = = = = = = = = =" />
							<log message="Cannot Execute [loadLCSLoadFile]" />
							<log message="  with parameters" />
							<log message="    [mapfile=@{mapfile}|datafile=@{datafile}|delimiter=@{delimiter}]" />
							<log message=" - ${errorLCS}" />
							<log message="= = = = = = = = = = = = = = = =" />
							<append.to.file message="ERROR ${csv.sep} loadLCSLoadFile ${csv.sep} [mapfile=@{mapfile}|datafile=@{datafile}|delimiter=@{delimiter}] ${csv.sep} ${errorLCS}" error="true" />
						</else>
					</if>
				</else>
			</if>
		</sequential>
	</macrodef>

	<!--    = = = = = = = = = = = = = = = = =
		      macrodef: loadLCSLoadFile
			 This Macrodef execute the loading of a Set of LCS Load Files
			    using an XML Input file containing filenames for all pairs mapFile,dataFile
		     = = = = = = = = = = = = = = = = = -->
	<macrodef name="loadLCSLoadFileSet" description="Load LCSLoadFile using XML FileList">
		<attribute name="xmlinputfile" />

		<sequential>
			<if>
				<available file="@{xmlinputfile}" />
				<then>
					<log />
					<log message="------------------------------" />
					<log message=" Loading a set of Flex LCS Load File" />
					<log message="    XML Input file [@{xmlinputfile}]" />
					<log message="------------------------------" />
					<log />

					<var name="currentxmlinputfilee" unset="true" />
					<property name="currentxmlinputfilee" value="@{xmlinputfile}"/>

					<groovy>
		                def xmlInputFile = ant.project.getProperty("currentxmlinputfilee");
		                def lcsLoadFileSet  = new XmlParser().parse(xmlInputFile);
		                
		                for (def lcsloadfile: lcsLoadFileSet.LCSLoadFile)
		                {
							mapfile = lcsloadfile.mapFile.'@filename';
							datafile = lcsloadfile.dataFile.'@filename';
							delim = lcsloadfile.'@delimiter';
							if (delim == null) {
								delim = "TAB";
							}
							ant.loadLCSLoadFile("mapfile": mapfile, "datafile": datafile, "delimiter": delim);
						}
						
		            </groovy>

				</then>
				<else>
					<log />
					<log />
					<log message="= = = = = = = = = = = = = = = =" />
					<log message="Cannot Execute [loadLCSLoadFileSet]" />
					<log message="  with parameters" />
					<log message="    [xmlinputfile=@{xmlinputfile}]" />
					<log message=" - File @{xmlinputfile} does not exist !" />
					<log message="= = = = = = = = = = = = = = = =" />
					<append.to.file message="ERROR ${csv.sep} loadLCSLoadFileSet ${csv.sep} [xmlinputfile=@{xmlinputfile}] ${csv.sep} File @{xmlinputfile} does not exist !" error="true" />
				</else>
			</if>

		</sequential>
	</macrodef>

	<!--    = = = = = = = = = = = = = = = = =
		      macrodef: installPackageSet
			 This Macrodef execute the Installation of a Set of Simple Change Package
			    using an XML Input file containing Package details
		     = = = = = = = = = = = = = = = = = -->
	<macrodef name="installPackageSet" description="Install a Set of Simple Change Package">
		<attribute name="xmlinputfile" />

		<sequential>
			<if>
				<available file="@{xmlinputfile}" />
				<then>
					<log />
					<log message="------------------------------" />
					<log message=" Loading a set of Simple Change Package" />
					<log message="    XML Input file [@{xmlinputfile}]" />
					<log message="------------------------------" />
					<log />

					<var name="currentxmlinputfilee" unset="true" />
					<property name="currentxmlinputfilee" value="@{xmlinputfile}"/>

					<groovy>
		                def xmlInputFile = ant.project.getProperty("currentxmlinputfilee");
		                def packageList  = new XmlParser().parse(xmlInputFile);
		                
		                for (def pack: packageList.Package)
		                {
							folder = pack.'@foldername';
						    confirmBeforeInstallation = pack.'@confirmbeforeinstallation';
							buildFile = pack.'@buildFile';
							if (buildFile == null) {
								buildFile = "build.xml";
							}
							target = pack.'@target';
							if (target == null) {
								target = "install";
							}
							ant.installPackage("folder": folder, "ask-confirmation": confirmBeforeInstallation, "build.file": buildFile, "target": target );
						}
		            </groovy>
				</then>
				<else>
					<log />
					<log />
					<log message="= = = = = = = = = = = = = = = =" />
					<log message="Cannot Execute [installPackageSet]" />
					<log message="  with parameters" />
					<log message="    [xmlinputfile=@{xmlinputfile}]" />
					<log message=" - File @{xmlinputfile} does not exist !" />
					<log message="= = = = = = = = = = = = = = = =" />
					<append.to.file message="ERROR ${csv.sep} installPackageSet ${csv.sep} [xmlinputfile=@{xmlinputfile}] ${csv.sep} File @{xmlinputfile} does not exist !" error="true" />
				</else>
			</if>
		</sequential>
	</macrodef>

	<!--    = = = = = = = = = = = = = = = = =
		      macrodef: installPackage
			 This Macrodef execute the Installation of a Simple Change Package 
		     = = = = = = = = = = = = = = = = = -->
	<macrodef name="installPackage" description="Install Package located on a given Folder">
		<attribute name="folder" />
		<attribute name="build.file" default="build.xml" />
		<attribute name="target" default="install" />
		<attribute name="ask-confirmation" default="true" />

		<sequential>

			<var name="loaded" unset="true"/>
			<var name="installer.basedir" unset="true"/>
			<var name="package.name" unset="true"/>
			<var name="package.name" unset="true"/>
			<var name="installation.log" unset="true"/>
			<var name="verbose.log" unset="true"/>
			<var name="info.log" unset="true"/>

			<property name="main.basedir" value="${basedir}"/>

			<var name="basedir" unset="true"/>
			<property name="basedir" value="@{folder}"/>

			<if>
				<istrue value="@{ask-confirmation}"/>
				<then>
					<var name="confirm.install" unset="true"/>
					<input message="Do you want to install Build located on folder [@{folder}] ?" defaultvalue="true" validargs="true,false" addproperty="confirm.install" />
				</then>
				<else>
					<property name="confirm.install" value="true"/>
				</else>
			</if>

			<if>
				<istrue value="${confirm.install}"/>
				<then>
					<trycatch property="antexecfail">
						<try >
							<ant antfile="@{folder}/@{build.file}" target="@{target}" inheritall="false" />
							<copy.folder.contents source="@{folder}/logs" target="${main.basedir}/logs" />
						</try>
						<catch>
							<log/>
							<log message="ERROR"/>
							<log message="${antexecfail}"/>
							<log/>
							<log message="WARNING ::: Problem found with Package on folder [@{folder}], check Installation Logs [@{folder}/logs]" />
							<append.to.file message="WARNING ${csv.sep} installPackage ${csv.sep} [folder=@{folder}] ${csv.sep} Problem found with Package on folder [@{folder}] - check Installation Logs [${main.basedir}/logs]" error="true" />
							<log/>
						</catch>
					</trycatch>
					<log/>
					<log message="Installation of Package from folder [@{folder}] end, please check Installation Logs [@{folder}/logs]" />
					<append.to.file message="SUCCESS ${csv.sep} installPackage ${csv.sep} [folder=@{folder}] ${csv.sep} Installation of Package from folder [@{folder}] Completed - check Installation Logs [${main.basedir}/logs]" />
					<log/>
				</then>
				<else>
					<log/>
					<log message="Installation of Package from folder [@{folder}] skipped !" />
					<append.to.file message="SKIPPED ${csv.sep} installPackage ${csv.sep} [folder=@{folder}] ${csv.sep} Installation Skipped by End User" />
					<log/>
				</else>
			</if>
		</sequential>

	</macrodef>
</project>
