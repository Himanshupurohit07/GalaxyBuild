	<!--    = = = = = = = = = = = = = = = = =
	      macrodef: loadCognosReports
		 This Macrodef execute the loading of Cognos Reports
	     = = = = = = = = = = = = = = = = = -->
	<macrodef name="loadCognosReports">
		<attribute name="folderpath" />

		<sequential>
			<if>
				<equals arg1="${list.content.only}" arg2="true" />
				<then>
					<log message="Print Package Content - Skipping loadCognosReports" />
				</then>
				<else>
					<if>
						<available file="@{folderpath}" type="dir" />
						<then>


							<modelupdate />

							<exec-cmd executable="${wc_cmd}" failonerror="true" action="loadCognosReports" parameters="[folderpath=@{folderpath}]">
								<args>
									<arg value="com.ptc.windchill.cognos.CognosProxy" />
									<arg value="loadreports" />
									<arg value="@{folderpath}" />
								</args>
							</exec-cmd>
						</then>
						<else>
							<log />
							<log />
							<log message="= = = = = = = = = = = = = = = =" />
							<log message="Cannot Execute [loadCognosReports]" />
							<log message="  with parameters" />
							<log message="    [folderpath=@{folderpath}]" />
							<log message=" - Folder @{folderpath} does not exist !" />
							<log message="= = = = = = = = = = = = = = = =" />
							<append.to.file message="ERROR ${csv.sep} loadCognosReports ${csv.sep} [folderpath=@{folderpath}] ${csv.sep} Folder @{folderpath} does not exist !" error="true"/>
						</else>
					</if>
				</else>
			</if>
		</sequential>
	</macrodef>



