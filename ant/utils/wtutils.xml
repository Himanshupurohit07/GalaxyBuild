<project name="Windchill Management Utilities">

	<!--  - - - - - - - - - - - - - - - - -  
        Private Target used to run different windchill command lines - which are separated by specific tasks
  			- - - - - - - - - - - - - - - - - -->
	<target name="WindchillCommand">
		<windchillCommand commandline="${line}" />
	</target>

	<!--    = = = = = = = = = = = = = = = = =
              macrodef: windchillCmd
        This Macrodef execute the     winchill commandline   command
             = = = = = = = = = = = = = = = = = -->
	<macrodef name="windchillCommand">
		<attribute name="commandline" />
		<attribute name="action" default="windchillCommand" />
		<attribute name="failonerror" default="true" />
		<attribute name="details" default="" />
		<element name="extra-args" optional="yes" description="Add command line extra arguments" />
		<sequential>

			<var name="theparameters" unset="true" />
			<if>
				<equals arg1="@{details}" arg2="" />
				<then>
					<property name="theparameters" value="[commandline=@{commandline}]" />
				</then>
				<else>
					<property name="theparameters" value="@{details}" />
				</else>
			</if>

			<if>
				<equals arg1="${list.content.only}" arg2="true" />
				<then>
					<log message="Print Package Content - Skipping WindchillCommand" />
				</then>
				<else>
					<exec-cmd executable="${wc_cmd}" failonerror="@{failonerror}" action="@{action}" parameters="${theparameters}">
						<args>
							<arg line="${extra.java.args}" />
							<arg value="@{commandline}" />
							<extra-args />
						</args>
					</exec-cmd>
				</else>
			</if>

		</sequential>
	</macrodef>

	<!--    = = = = = = = = = = = = = = = = =
              macrodef: exec-cmd
        This Macrodef execute the     winchill cmd   command  
		    <exec-cmd executable="${wc_cmd}" failonerror="true" action="name of source macrodef or target" parameters="relevant parameters">
				<args>
					<arg value="ddd"/>
				</args>
			</exec-cmd>
             = = = = = = = = = = = = = = = = = -->
	<macrodef name="exec-cmd">
		<attribute name="executable" default="${wc_cmd}" />
		<attribute name="inputstring" default="" />
		<attribute name="resultproperty" default="retCode" />
		<attribute name="failonerror" default="true" />
		<attribute name="checksumreference" default="" />
		<attribute name="requestedpassword" default="false" />
		<attribute name="enforce" default="false" />
		<attribute name="action" />
		<attribute name="parameters" />
		<element name="args" optional="yes" description="Add command line arguments" />
		<sequential>

			<if>
				<not>
					<equals arg1="@{checksumreference}" arg2="" />
				</not>
				<then>
					<compareChecksum file="@{checksumreference}" />
					<log />
					<log message="Checking for changes in @{checksumreference}" />
					<if>
						<istrue value="${isMD5ok}" />
						<then>
							<log message="-- SAME MD5 => Had already been successfully Executed" />
							<log />
						</then>
						<else>
							<log message="-- DIFFERENT MD5 => New File" />
							<log />
						</else>
					</if>
				</then>
			</if>

			<if>
				<and>
					<istrue value="${isMD5ok}" />
					<istrue value="${skip.already.loaded.files}" />
					<not>
						<istrue value="@{enforce}" />
					</not>
				</and>
				<then>
					<log message="-- Skipping Execution of command [@{action}] on file [@{checksumreference}]  (Same file already installed via a prior Installation)" />
					<append.to.file message="SKIPPED ${csv.sep} @{action} ${csv.sep} @{parameters} ${csv.sep} @{checksumreference} had already been installed via on a prior installation" />
				</then>
				<else>
					<log />
					<checkAuth requestedpassword="@{requestedpassword}" />
					<log />
					<var name="executionstamp" unset="true" />
					<tstamp>
						<format property="executionstamp" pattern="yyyy/MM/dd - hh:mm:ss aa z" />
					</tstamp>
					<log message="= = = = = = = = = = = = = = = =" />
					<log message="Execute [@{action}]" />
					<log message=" - with parameters" />
					<log message="    @{parameters}" />
					<log message=" - at ${executionstamp}" />
					<log message="= = = = = = = = = = = = = = = =" />

					<switch.verbose.log.recorder.to.info />

					<var name="logcommandexecfail" unset="true" />
					<trycatch property="logcommandexecfail">
						<try>
							<log-exec-cmd>
								<exec-cmd>
									<exec failonerror="@{failonerror}" executable="@{executable}" resultproperty="@{resultproperty}" inputstring="@{inputstring}">
										<args />
									</exec>
								</exec-cmd>
							</log-exec-cmd>
						</try>
						<catch>
							<log />
							<log message="WARNING" />
							<log message="${logcommandexecfail}" />
							<log />
							<log message=" !! Logging @{action} with parameters @{parameters} fails !!" />
							<log />
						</catch>
					</trycatch>

					<var name="commandexecfail" unset="true" />
					<trycatch property="commandexecfail">
						<try>
							<exec failonerror="@{failonerror}" executable="@{executable}" resultproperty="@{resultproperty}" inputstring="@{inputstring}">
								<args />
							</exec>
						</try>
						<catch>
							<log />
							<log />
							<log message="ERROR" />
							<log message="${commandexecfail}" />
							<log />
							<log message=" !! Executing @{action} with parameters @{parameters} fails !! Check Method Server logs for more details" />
							<log />
							<append.to.file errormessage="ERROR:   @{parameters}" error="true" />
						</catch>
					</trycatch>

					<if>
						<isset property="commandexecfail" />
						<then>
							<append.to.file message="ERROR ${csv.sep} @{action} ${csv.sep} @{parameters} ${csv.sep} ${cmd-line}" />
						</then>
						<else>
							<captureChecksum file="@{checksumreference}" />
							<append.to.file message="SUCCESS ${csv.sep} @{action} ${csv.sep} @{parameters}" />
						</else>
					</if>

					<switch.verbose.log.recorder.to.verbose />
				</else>
			</if>
		</sequential>
	</macrodef>

	<macrodef name="log-exec-cmd">
		<element name="exec-cmd" optional="no" />
		<sequential>
			<echoxml file="${installer.logs.dir}/command.xml">
				<exec-cmd />
			</echoxml>
			<groovy>
                def installerLogsDir = ant.project.getProperty("installer.logs.dir");
                def password = ant.project.getProperty("wcadmin.password");
                def fullpath = installerLogsDir+"/command.xml";
                def execCmd  = new XmlParser().parse(fullpath);
                def commandline = execCmd.'@executable';
                def replacepassword = false;
                if ( password != null ) {
                    password = password.trim();
                    if ( password.size() >0 ) {
                        replacepassword=true;
                    }
                }

                for (def argument: execCmd.arg)
                {
                    def argval=argument.'@value';
                    if ( argval == null ) {
                        argval=argument.'@line';
                    }

                    if ( argval != null ) {
                        if ( replacepassword )  {
                            if ( argval.indexOf(password)!=-1 ) {
                                argval = argval.replaceAll(password,'\\$WDCPASS');
                            }
                        }
                        commandline = commandline + " " + argval;
                    }
                }
                ant.project.setProperty("cmd-line",commandline);
            </groovy>
			<log />
			<log message="Executing:" />
			<log message="${cmd-line}" />
			<log />

			<if>
				<available file="${installer.logs.dir}/command.xml" />
				<then>
					<delete quiet="true" failonerror="false" file="${installer.logs.dir}/command.xml" />
				</then>
			</if>

		</sequential>
	</macrodef>


