	<!--    = = = = = = = = = = = = = = = = =
              macrodef: setLogLevel
        This Macrodef execute the    wt.util.jmx.SetLogLevel    command  
             = = = = = = = = = = = = = = = = = -->
	<macrodef name="setLogLevel">
		<attribute name="logger" />
		<attribute name="loglevel" default="ERROR" />
		<sequential>
			<log />
			<log message="START - Executing wt.util.jmx.SetLogLevel @{logger} @{loglevel} command" />
			<log />
			<if>
				<not>
					<equals arg1="X@{logger}" arg2="X" />
				</not>
				<then>
					<exec-cmd executable="${wc_cmd}" failonerror="false" action="SetLogLevel" parameters="[logger=@{logger},loglevel=@{loglevel}]">
						<args>
							<arg value="wt.util.jmx.SetLogLevel" />
							<arg line="@{logger}" />
							<arg value="@{loglevel}" />
						</args>
					</exec-cmd>
				</then>
				<else>
					<log message=" Warning: Cannot execute SetLogLevel with parameter [logger] Empty !" />
				</else>
			</if>

			<log />
			<log message="END   - Command wt.util.jmx.SetLogLevel executed" />
			<log />
		</sequential>
	</macrodef>

	<!--    = = = = = = = = = = = = = = = = =
              macrodef: backupExistingLWCTypeImpExpFiles
        This Macrodef Backup the existing   LWCTypeImpExp folder before build deployment
        	In case files exist on this folder after deployment, it means that Windchill has detected Datamodel deletion during SoftType loading 
             = = = = = = = = = = = = = = = = = -->
	<macrodef name="backupExistingLWCTypeImpExpFiles">
		<sequential>
			<log />
			<log message="START - Backup Existing LWCTypeImpExp Files" />
			<log />
			<tstamp>
				<format property="dirTimePostFix" pattern="yyyy-MM-dd_HHmmssSSS" />
			</tstamp>
			<move file="${wt.temp}/LWCTypeImpExp" tofile="${wt.temp}/LWCTypeImpExp_${dirTimePostFix}" failonerror="false" />
			<mkdir dir="${wt.temp}/LWCTypeImpExp" />
			<log />
			<log message="END   - Existing LWCTypeImpExp Files backup on folder [${wt.temp}/LWCTypeImpExp_${dirTimePostFix}]" />
			<log />
		</sequential>
	</macrodef>

	<!--    = = = = = = = = = = = = = = = = =
              macrodef: loadLWCTypeImpExpFiles
        This Macrodef Load (or Log the command to execute) based on the files generated on folder LWCTypeImpExp during installation
        	By default nothing will be deleted, but command to be executed will be listed on the Delivery Note
        		2 options exist:  autoDeleteType  and autoDeleteAttributes which can be used to automatically trigger these deletions.
        			 <loadLWCTypeImpExpFiles autoDeleteTypes="true" autoDeleteAttributes="true" /> 
        			 	added on the extension file would automatically execute the Delete Loader for both Types and Attributes.
             = = = = = = = = = = = = = = = = = -->
	<macrodef name="loadLWCTypeImpExpFiles">
		<attribute name="autoDeleteTypes" default="${lwctypeimpexp.autodeletetypes}" />
		<attribute name="autoDeleteAttributes" default="${lwctypeimpexp.autodeleteattributes}" />
		<sequential>
			<log />
			<log message="START - Load LWCTypeImpExp Files" />
			<log />


			<!-- Rename files containing "$" character on their name, "$" is replaced by an "_"  -->
			<move todir="${wt.temp}/LWCTypeImpExp" verbose="true" overwrite="true" failonerror="false">
				<fileset dir="${wt.temp}/LWCTypeImpExp" includes="**" />
				<regexpmapper from="(.*)[$$](.*)" to="\1_\2" />
			</move>

			<fileset id="typesToDelete" dir="${wt.temp}/LWCTypeImpExp">
				<include name="DELETE_TYPES_*.xml" />
			</fileset>
			<fileset id="attributesToDelete" dir="${wt.temp}/LWCTypeImpExp">
				<exclude name="DELETE_TYPES_*.xml" />
				<include name="*.xml" />
			</fileset>

			<var name="theTypesToDelelete" unset="true" />
			<property name="theTypesToDelelete" refid="typesToDelete" />
			<for list="${theTypesToDelelete}" delimiter=";" param="file">
				<sequential>
					<if>
						<equals arg1="@{autoDeleteTypes}" arg2="true" />
						<then>
							<loadFromFile loadfile="${wt.temp}/LWCTypeImpExp/@{file}" />
						</then>
						<else>
							<append.to.file message="SKIPPED ${csv.sep} loadLWCTypeImpExpFiles ${csv.sep} [loadfile=${wt.temp}/LWCTypeImpExp/@{file}] ${csv.sep} The Delete Type file [@{file}] generated by Windchill during installation has not be Loaded (Param [autoDeleteTypes] != true) ${csv.sep} Review with Customer then execute manually executing command [ ${wc_cmd} ${extra.java.args} wt.load.LoadFromFile -d @{file} ${username.and.password} -CONT_PATH / ]" />
						</else>
					</if>
				</sequential>
			</for>

			<var name="theAttributesToDelelete" unset="true" />
			<property name="theAttributesToDelelete" refid="attributesToDelete" />
			<for list="${theAttributesToDelelete}" delimiter=";" param="file">
				<sequential>
					<if>
						<equals arg1="@{autoDeleteAttributes}" arg2="true" />
						<then>
							<loadFromFile loadfile="${wt.temp}/LWCTypeImpExp/@{file}" />
						</then>
						<else>
							<append.to.file message="SKIPPED ${csv.sep} loadLWCTypeImpExpFiles ${csv.sep} [loadfile=${wt.temp}/LWCTypeImpExp/@{file}] ${csv.sep} The Delete Attribute file [@{file}] generated by Windchill during installation has not be Loaded (Param [autoDeleteAttributes] != true) ${csv.sep} Execute manually executing command [ ${wc_cmd} ${extra.java.args} wt.load.LoadFromFile -d @{file} ${username.and.password} -CONT_PATH / ]" />
						</else>
					</if>
				</sequential>
			</for>

			<log />
			<log message="END   - LWCTypeImpExp Files loaded" />
			<log />
		</sequential>
	</macrodef>

