	<!--    = = = = = = = = = = = = = = = = =
              macrodef: disableExtraMS
        This Macrodef reconfigure property "wt.manager.monitor.service" to "MethodServer".
           and property "wt.manager.monitor.start.MethodServer" to "1"
         It stores as well on a file ./original.site.propertie the original values of these 2 properties
             = = = = = = = = = = = = = = = = = -->
	<macrodef name="disableExtraMS">
		<sequential>
			<log />
			<log message="START - Disabling extra MethodServer and BackgroundMethodServer" />
			<log message="---------------------------------------------------------" />
			<log />
			<property name="original.monitor.services" value="${wt.manager.monitor.services}" />
			<property name="original.number.of.ms" value="${wt.manager.monitor.start.MethodServer}" />



			<log message=" - List of Monitor Services: ${original.monitor.services}" />
			<log message=" - Number of Method Servers before deployment starts: ${original.number.of.ms}" />

			<log message="   - Storing properties in file: [${installer.basedir}${file.separator}original.site.properties] " />
			<propertyfile file="${installer.basedir}${file.separator}original.site.properties" comment="Capture MS and BGMS site properties">
				<entry key="original.number.of.ms" value="${original.number.of.ms}" />
				<entry key="original.monitor.services" value="${original.monitor.services}" />
			</propertyfile>

			<if>
				<not>
					<equals arg1="${original.number.of.ms}" arg2="1" />
				</not>
				<then>
					<log message="   - Changing Number of MethodServer to 1" />
					<log message=" - Changing value of property [wt.manager.monitor.start.MethodServer] from [${original.number.of.ms}] to [1]" />
					<xconf.s property="wt.manager.monitor.start.MethodServer" value="1" targetfile="codebase/wt.properties" />
				</then>
			</if>

			<if>
				<not>
					<equals arg1="${original.monitor.services}" arg2="MethodServer" />
				</not>
				<then>
					<log message="   - Disabling BackgroundMethodServer" />
					<log message=" - Changing value of property [wt.manager.monitor.services] from [${original.monitor.services}] to [MethodServer]" />
					<xconf.s property="wt.manager.monitor.services" value="MethodServer" targetfile="codebase/wt.properties" />
				</then>
			</if>

			<log />
			<log message="---------------------------------------------------------" />
			<log message="END   - Extra MethodServer and BackgroundMethodServer Disabled" />
			<log />
		</sequential>
	</macrodef>

	<!--    = = = = = = = = = = = = = = = = =
              macrodef: enableExtraMS
        This Macrodef reconfigure property "wt.manager.monitor.service" and property "wt.manager.monitor.start.MethodServer" 
           to their original values as captured in file ./original.site.properties before reconfiguration
           
             = = = = = = = = = = = = = = = = = -->
	<macrodef name="enableExtraMS">
		<sequential>
			<log />
			<log message="START - Re-Enabling Extra MethodServer and BackgroundMethodServer " />
			<log message="---------------------------------------------------------" />
			<log />

			<if>
				<available file="${installer.basedir}${file.separator}original.site.properties" />
				<then>
					<property file="${installer.basedir}${file.separator}original.site.properties" />
				</then>
			</if>

			<if>
				<and>
					<not>
						<equals arg1="${original.number.of.ms}" arg2="1" />
					</not>
					<not>
						<equals arg1="X${original.number.of.ms}" arg2="X" />
					</not>
				</and>
				<then>
					<log message=" - Changing value of property [wt.manager.monitor.start.MethodServer] from [1] to [${original.number.of.ms}]" />
					<xconf.s property="wt.manager.monitor.start.MethodServer" value="${original.number.of.ms}" targetfile="codebase/wt.properties" />
				</then>
			</if>

			<if>
				<and>
					<not>
						<equals arg1="${original.monitor.services}" arg2="MethodServer" />
					</not>
					<not>
						<equals arg1="X${original.monitor.services}" arg2="X" />
					</not>
				</and>
				<then>
					<log message=" - Changing value of property [wt.manager.monitor.services] from [MethodServer] to [${original.monitor.services}]" />
					<xconf.s property="wt.manager.monitor.services" value="${original.monitor.services}" targetfile="codebase/wt.properties" />
				</then>
			</if>
			<log />
			<log message="---------------------------------------------------------" />
			<log message="END   - Extra MethodServer and BackgroundMethodServer Re-Enabled" />
			<log />
		</sequential>
	</macrodef>

	<!--    = = = = = = = = = = = = = = = = =
              macrodef: encryptAllPasswords
        This Macrodef execute the target "encryptAllPasswords" of the EncryptPasswords.xml Ant script.
           The list of properties being encrypted can be found on folder  ${wt.home}/bin/adminTools/sip
             = = = = = = = = = = = = = = = = = -->
	<macrodef name="encryptAllPasswords">
		<sequential>
			<log />
			<log message="START - Encrypt All Passwords" />
			<log />
			<log message="   - Execute Windchill Command to Encrypt all windchill Passwords listed on file [${wt.home}/bin/adminTools/sip/validProperties.list]" />
			<log />
			<ant antfile="${wt.home}/bin/adminTools/sip/EncryptPasswords.xml" dir="${wt.home}/bin/adminTools/sip" target="encryptAllPasswords" inheritrefs="true" />
			<log />
			<log message="END   - All Passwords Encrypted" />
			<log />
		</sequential>
	</macrodef>

	<!--    = = = = = = = = = = = = = = = = =
              macrodef: encryptValueOfProperty
        This Macrodef execute the target "encryptPw" of the EncryptPasswords.xml Ant script.
           The value of the property given in parameter will be encrypted and propagated to Windchill Property files.
           Usage <encryptValueOfProperty property="aKey" value="aPassword" />
           
           Warning: thlse propertyName must have been already declared as an encrypted Property on file called 
              ${wt.home}/bin/adminTools/sip/validProperties.list
           
             = = = = = = = = = = = = = = = = = -->
	<macrodef name="encryptValueOfProperty">
		<attribute name="property" />
		<attribute name="value" />
		<sequential>
			<log />
			<log message="START - Encrypt a Property Value" />
			<log />
			<log message="   - Execute Windchill Command to Encrypt the provided property [@{property}]" />
			<log />
			<ant antfile="${wt.home}/bin/adminTools/sip/EncryptPasswords.xml" dir="${wt.home}/bin/adminTools/sip" target="encryptPw" inheritrefs="true">
				<property name="propertyName" value="@{property}" />
				<property name="password" value="@{value}" />
			</ant>
			<log />
			<xconf.p force="false" />
			<log />
			<log message="END   - Property [@{property}] has been encrypted" />
			<log />
		</sequential>
	</macrodef>

	<!--    = = = = = = = = = = = = = = = = =
              macrodef: get.component.version
        This Macrodef extract from a <comnponent>.ia file the releaseIdentifier.
           The releaseIdentifier is then split in various properties
               <component>.major
               <component>.minor
               <component>.point
               <component>.cps
               <component>.build
           They can then be called using ${<component>.major} for instance
           If the component is not installed, a property  ${<component>.installed} is set to false
           Default component name is "wnc"
             = = = = = = = = = = = = = = = = = -->
	<macrodef name="get.component.version">
		<attribute name="component" default="wnc" />
		<sequential>

			<if>
				<available file="${installregistry.dir}/@{component}.ia" />
				<then>
					<var name="currentcomponent" unset="true" />
					<property name="currentcomponent" value="@{component}" />
					<groovy>
                        def path = ant.project.getProperty("installregistry.dir");
                        def compo = ant.project.getProperty("currentcomponent");
                        def fullpath = path+"/"+compo+".ia";
                        def installedAssembly  = new XmlParser().parse(fullpath);
                        def vers = installedAssembly.'@releaseIdentifier';
                        def vals = vers.trim().split('\\.');
                        def index = 0;
                        def map = [1: "component", 2: "major", 3: "minor", 4: "point", 5: "cps", 6: "build"];

                        for (String exp : vals) {
                                index++
                                def key = compo+"."+map[index];
                                ant.project.setProperty(key,exp);
                        }
                    </groovy>
					<property name="@{component}.installed" value="true" />
				</then>
				<else>
					<property name="@{component}.installed" value="false" />
				</else>
			</if>

		</sequential>
	</macrodef>

	<!--    = = = = = = = = = = = = = = = = =
              macrodef: display.component.version
        This Macrodef execute get.component.version before displaying the result.
           Default component name is "wnc"
             = = = = = = = = = = = = = = = = = -->
	<macrodef name="display.component.version">
		<attribute name="component" default="wnc" />
		<attribute name="ignore.if.not.installed" default="false" />
		<sequential>

			<get.component.version component="@{component}" />

			<if>
				<istrue value="${@{component}.installed}" />
				<then>
					<log message=" - ${@{component}.component} Version:   " />
					<log message="             Major: ${@{component}.major} " />
					<log message="             Minor: ${@{component}.minor} " />
					<log message="             Point: ${@{component}.point} " />
					<log message="               CPS: ${@{component}.cps}   " />
					<log message="       BuildNumber: ${@{component}.build} " />
				</then>
				<else>
					<if>
						<not>
							<istrue value="@{ignore.if.not.installed}" />
						</not>
						<then>
							<log />
							<log message=" - @{component} component is not installed ! " />
							<log />
						</then>
					</if>
				</else>
			</if>
		</sequential>
	</macrodef>

	<!--    = = = = = = = = = = = = = = = = =
              macrodef: flex.add.columns.exec
        This Macrodef execute the  Add Columns for Flex PLM  
          Example: 
            <flex.add.columns.exec
               columns="wt.part.WTPart String=2 Long=0 Double=0 Boolean=0 Timestamp=0 ObjectReference=0 VersionReference=0 InlineBLOB=0"
            />
             = = = = = = = = = = = = = = = = = -->
	<macrodef name="flex.add.columns.exec">
		<attribute name="columns" />
		<sequential>
			<exec-cmd executable="AddColumns.sh" failonerror="true" action="Execute Add Columns" parameters="[@{columns}]">
				<args>
					<arg value="-a" />
					<arg value="-f" />
					<arg line="@{columns}" />
				</args>
			</exec-cmd>
		</sequential>
	</macrodef>

	<!--    = = = = = = = = = = = = = = = = =
              macrodef: flex.add.columns.apply
        This Macrodef execute the Add Columns to Sync changes with DB  
          Example: 
            <flex.add.columns.apply />
             = = = = = = = = = = = = = = = = = -->
	<macrodef name="flex.add.columns.apply">
		<sequential>
			<exec-cmd executable="AddColumns.sh" failonerror="true" action="Apply Add Columns" parameters="[]">
				<args>
					<arg value="-u" />
					<arg value="-s" />
				</args>
			</exec-cmd>
		</sequential>
	</macrodef>
</project>
