	<!-- ================================= 
        Copy to Windchill all Files provided with this distribution
              ================================= -->
	<target depends="default.copy.files" description="Copy Configuration Files"
           name="copy.files">
		<!--   Copy File Section  -->
		<!-- EXAMPLES :  
	        By default folders ./loadFiles, ./loadXMLFiles, ./codebase, ./wtCustom, ./tasks, 
	        	                   ./srclib, ./lib, ./wtSafeArea, ./db, ./installer, ./ant/lib and ./conf
	        	         are automatically copied to $WT_HOME without additions. 
	        	     ref: Target default.copy.files on file /ant/utils/copy.xml
	        	     
	         Any files or folder not on this list has to be declared here after as follows:
	         
	      <copy.folder.contents source="${basedir}/somedirectory" target="${wt.home}/somedirectory" />
		    or
		  <copy overwrite="true" verbose="${copy.verbose}" todir="${wt.home}/somedirectory" failonerror="false" >
				<fileset dir="./somedirectory">
					<include name="**/*"/>
					<exclude name="**/.svn"/>
					<exclude name="**/*.settings"/>
					<exclude name="**/*.classpath"/>
					<exclude name="**/*.project"/>
				</fileset>
	      </copy>
		-->
		<!-- ADD The specific copyFile declarations here after -->
		
		<copy file="${wt.loadfiles.dir}/sic/conf/queryBuilderMethods.xml" todir="${wt.home}/conf" overwrite="true"/>
	</target>

	  <!-- ================================= 
        Declare files to be deleted permanently
  			================================= -->
	<target description="Delete Files" name="delete.files">
		<!-- This is called after copy.files during installation and it is always executed. 
			Files deleted using these macrodefs are kept on an Archive called uninstaller_package.name_deletedFiles.jar -->
		<!-- EXAMPLES :
		   - Delete from wt.home
		       	<deleteFile filename="codebase/xxx.properties"/>
		   - Delete from a given directory
		       	<deleteFile filename="xxx.properties"  filepath="${wt.home}/codebase" />
		   - Delete a set of files (File named as *xx.bak on the given folder)
		       	<deleteFile filename="*xx.bak"  filepath="${wt.home}/codebase" />
		   - Delete a set of files (File named as *xx.bak on all folders recursively)
		       	<deleteFile filename="**/*xx.bak"  filepath="${wt.home}/codebase" />
		   - Delete a Folder
		       	<deleteFolder dir="${wt.home}/codebase/acustomfolder" />
		-->
		<!-- ADD The specific delete declarations here after -->
		
	</target>

	  <!-- ================================= 
        Declare all Xconf modification to apply with this distribution
              ================================= -->
	<target depends="default.deploy.xconf" description="Deploy Xconf Files and Properties"
           name="deploy.xconf">
		<!--   XCONF Section  -->
		<!-- EXAMPLES: 
           - Reference (include) an xconf file to declarations.xconf
       	<xconf.i filetoinclude="codebase/com/customer/customer_default_configuration.xconf" />
           - Reference (link) an xconf file to site.xconf
       	<xconf.l filetoinclude="codebase/com/customer/customer.xconf" />
           - Substitute a property value via site.xconf
       	<xconf.s property="publish.copyforwardallrepresentationsoncopy" 
       		 value="false" 	
       		 targetfile="codebase/WEB-INF/conf/wvs.properties" />
        	- Add a property value to a Multiple Values property
        <xconf.a property="com.lcs.wc.util.LCSProperties.additionalProperties" 
        	 value="/myPropertyFile.properties" />
           - Propagate Xconf Changes (executed by default by all other xconf.* targets)
		<xconf.p/>
		-->
		<!-- ADD The specific XConf declarations here after -->

		<xconf.s property="com.sparc.webservice" 
       		 value="ext.addcolumn.RestUtil,com.sparc.wc.integration.SparcRestIntegration" 	
       		 targetfile="codebase/com/ptc/windchill/rest/rest.properties"/>
	</target>

